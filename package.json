{
  "name": "gurukulams-website",
  "version": "1.0.0",
  "description": "Gurukulams Website",
  "source": "src/index.html",
  "author": "Sathish Kumar Thiyagarajan",
  "license": "ISC",
  "scripts": {
    "clean": "rimraf dist",
    "watch:site": "onchange \"site\" -- run-s build:site",
    "watch:questions": "onchange \"site\" -- run-s build:site",
    "start": "npm run build && run-p watch:* serve",
    "serve": "webpack serve",
    "build:js": "webpack",
    "build:site": "hugo --minify -d ../dist -s site",
    "build:questions": "copyfiles \"data/**/*\" dist/",
    "build": "run-s clean build:*",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.7",
    "clean-webpack-plugin": "^4.0.0",
    "copyfiles": "^2.4.1",
    "html-loader": "^5.1.0",
    "hugo-bin": "0.144.8",
    "npm-run-all": "4.1.5",
    "onchange": "^7.1.0",
    "qrious": "^4.0.2",
    "rimraf": "^6.0.1",
    "webpack": "5.99.9",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "5.2.2"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "easymde": "^2.20.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "quill": "^2.0.3"
  }
}
